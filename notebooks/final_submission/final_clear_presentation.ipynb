      "cell_type": "code",
      "source": [
        "import os\n",
        "import matplotlib.pyplot as plt\n",
        "import numpy as np\n",
        "\n",
        "# 檢查並自動建立符合專案規範的圖表輸出資料夾\n",
        "# Check and automatically create the standard output directory for figures\n",
        "os.makedirs('outputs/figures', exist_ok=True)\n",
        "\n",
        "# 建立群組名稱與對應的吸菸比例數據\n",
        "# Define group names and their corresponding smoking proportions\n",
        "groups = ['Group 1: Sad or Hopeless', 'Group 2: Not Sad']\n",
        "proportions = [0.2760, 0.1618]\n",
        "\n",
        "# 根據推論統計計算出的 95% 信賴區間誤差長度\n",
        "# Calculated 95% CI error lengths derived from inferential statistics\n",
        "ci_errors = [0.0141, 0.0075]\n",
        "\n",
        "# 初始化圖表大小並繪製長條圖\n",
        "# Initialize figure size and draw the bar chart\n",
        "plt.figure(figsize=(8, 5.5))\n",
        "bars = plt.bar(groups, proportions, yerr=ci_errors, capsize=8,\n",
        "               color=['#e74c3c', '#3498db'], alpha=0.85, width=0.5,\n",
        "               error_kw=dict(ecolor='#2c3e50', lw=2, capthick=2))\n",
